# ── Gzip compression ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml text/plain
</IfModule>

# ── Browser caching ──────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # Vendor JS/CSS — cache 1 year (filenames won't change)
    <FilesMatch "\.(js|css)$">
        ExpiresDefault "access plus 1 year"
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Images & fonts — cache 1 month
    <FilesMatch "\.(png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf)$">
        ExpiresDefault "access plus 1 month"
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    # PHP pages — always revalidate
    <FilesMatch "\.php$">
        ExpiresDefault "access plus 0 seconds"
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# ── Keep-Alive ───────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>
